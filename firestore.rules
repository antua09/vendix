rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /sales/{saleId} {
      allow read: if request.auth != null && !exists(/databases/$(database)/documents/banned/$(request.auth.uid));
      allow create: if request.auth != null && request.resource.data.sellerId == request.auth.uid
                    && !exists(/databases/$(database)/documents/banned/$(request.auth.uid));
      allow delete: if request.auth != null && resource.data.sellerId == request.auth.uid;
    }

    match /users/{userId}/privateSales/{saleId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /chat/{msgId} {
      allow read: if request.auth != null && !exists(/databases/$(database)/documents/banned/$(request.auth.uid));
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid
                    && !exists(/databases/$(database)/documents/banned/$(request.auth.uid));
    }

    match /banned/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == "TU_UID_AQUI";
    }
  }
}
